<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.bryan.fitbit-scale-exporter</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/env</string>
        <string>swift</string>
        <string>run</string>
        <string>fitbit-scale-exporter</string>
        <string>export</string>
        <string>--client-id</string>
        <string>YOUR_FITBIT_CLIENT_ID</string>
        <string>--token-file</string>
        <string>/Users/bryan/.fitbit-scale-sync/token.json</string>
        <string>--output</string>
        <string>/Users/bryan/Library/Mobile Documents/com~apple~CloudDocs/FitbitScale/latest-weight.json</string>
        <string>--weight-unit</string>
        <string>pounds</string>
        <string>--latest-only</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/bryan/Documents/Codex/Fitbit Scale</string>

    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>8</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>/Users/bryan/Library/Logs/fitbit-scale-exporter.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/bryan/Library/Logs/fitbit-scale-exporter.log</string>
</dict>
</plist>
